generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  BLOCKED
  PENDING
}

enum RequestStatus {
  NEW
  IN_REVIEW
  CONFIRMED
  PROCESSING
  COMPLETED
  CANCELLED
}

enum AdminStatus {
  ACTIVE
  BLOCKED
}

enum ConsultationStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum NotificationType {
  REQUEST_STATUS_CHANGED
  CONSULTATION_RESPONSE
  SYSTEM
}

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
  TELEGRAM
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

model User {
  id                String         @id @default(uuid())
  firstName         String?
  lastName          String?
  email             String?        @unique
  phone             String?        @unique
  passwordHash      String
  isEmailVerified   Boolean        @default(false)
  isPhoneVerified   Boolean        @default(false)
  status            UserStatus     @default(PENDING)
  favorites         Favorite[]
  cartItems         CartItem[]
  requestOrders     RequestOrder[]
  viewedProducts    ProductView[]
  notificationPrefs NotificationPreference[]
  notifications     Notification[]
  consultations     ConsultationRequest[]
  comparisons       ProductComparison[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model Product {
  id                String             @id @default(uuid())
  name              String
  slug              String             @unique
  sku               String?            @unique
  brandId           String?
  categoryId        String?
  shortDescription  String?
  fullDescription   String?
  usageMethod       String?
  benefits          String?
  precautions       String?
  volume            String?
  isActive          Boolean            @default(true)
  sortOrder         Int                @default(0)
  brand             Brand?             @relation(fields: [brandId], references: [id])
  category          Category?          @relation(fields: [categoryId], references: [id])
  taskLinks         ProductCareTask[]
  favorites         Favorite[]
  cartItems         CartItem[]
  requestItems      RequestOrderItem[]
  instructions      Instruction[]
  faqItems          FaqItem[]
  careKitItems      CareKitItem[]
  viewedByUsers     ProductView[]
  comparisonItems   ProductComparisonItem[]
  consultationLinks ConsultationRequestProduct[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model Category {
  id          String      @id @default(uuid())
  name        String
  slug        String      @unique
  description String?
  parentId    String?
  isActive    Boolean     @default(true)
  parent      Category?   @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[]  @relation("CategoryTree")
  products    Product[]
}

model Brand {
  id          String      @id @default(uuid())
  name        String
  slug        String      @unique
  description String?
  logoMediaId String?
  isActive    Boolean     @default(true)
  logoMedia   MediaFile?  @relation(fields: [logoMediaId], references: [id])
  products    Product[]
}

model CareTask {
  id                 String             @id @default(uuid())
  name               String
  slug               String             @unique
  shortDescription   String?
  fullDescription    String?
  problemDescription String?
  stepByStep         String?
  faqBlock           String?
  isActive           Boolean            @default(true)
  productLinks       ProductCareTask[]
  instructions       Instruction[]
  faqItems           FaqItem[]
  careKits           CareKit[]
  consultationRequests ConsultationRequest[]
}

model ProductCareTask {
  productId  String
  careTaskId String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  careTask   CareTask @relation(fields: [careTaskId], references: [id], onDelete: Cascade)

  @@id([productId, careTaskId])
}

model Article {
  id           String     @id @default(uuid())
  title        String
  slug         String     @unique
  previewText  String?
  content      String
  coverMediaId String?
  authorId     String?
  isPublished  Boolean    @default(false)
  publishedAt  DateTime?
  coverMedia   MediaFile? @relation(fields: [coverMediaId], references: [id])
  author       Admin?     @relation(fields: [authorId], references: [id])
}

model Instruction {
  id               String    @id @default(uuid())
  title            String
  slug             String    @unique
  content          String
  relatedProductId String?
  relatedTaskId    String?
  isPublished      Boolean   @default(false)
  relatedProduct   Product?  @relation(fields: [relatedProductId], references: [id])
  relatedTask      CareTask? @relation(fields: [relatedTaskId], references: [id])
}

model FaqItem {
  id               String    @id @default(uuid())
  question         String
  answer           String
  sortOrder        Int       @default(0)
  isPublished      Boolean   @default(true)
  relatedProductId String?
  relatedTaskId    String?
  relatedProduct   Product?  @relation(fields: [relatedProductId], references: [id])
  relatedTask      CareTask? @relation(fields: [relatedTaskId], references: [id])
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  productId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model CartItem {
  id        String   @id @default(uuid())
  userId    String
  productId String
  quantity  Int      @default(1)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
}

model RequestOrder {
  id             String                 @id @default(uuid())
  userId         String
  status         RequestStatus          @default(NEW)
  customerName   String
  customerEmail  String?
  customerPhone  String?
  comment        String?
  adminComment   String?
  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  items          RequestOrderItem[]
  statusHistory  RequestStatusHistory[]
  notifications  Notification[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
}

model RequestOrderItem {
  id                  String       @id @default(uuid())
  requestOrderId      String
  productId           String?
  productNameSnapshot String
  quantity            Int          @default(1)
  requestOrder        RequestOrder @relation(fields: [requestOrderId], references: [id], onDelete: Cascade)
  product             Product?     @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model RequestStatusHistory {
  id               String        @id @default(uuid())
  requestOrderId   String
  oldStatus        RequestStatus?
  newStatus        RequestStatus
  changedByAdminId String?
  comment          String?
  requestOrder     RequestOrder  @relation(fields: [requestOrderId], references: [id], onDelete: Cascade)
  changedByAdmin   Admin?        @relation(fields: [changedByAdminId], references: [id], onDelete: SetNull)
  createdAt        DateTime      @default(now())
}

model Admin {
  id           String       @id @default(uuid())
  name         String
  email        String       @unique
  passwordHash String
  status       AdminStatus  @default(ACTIVE)
  roles        AdminRole[]
  articles     Article[]
  statusLogs   RequestStatusHistory[]
  consultations ConsultationRequest[]
  createdAt    DateTime     @default(now())
}

model Role {
  id         String      @id @default(uuid())
  name       String
  code       String      @unique
  admins     AdminRole[]
}

model AdminRole {
  adminId String
  roleId  String
  admin   Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)
  role    Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([adminId, roleId])
}

model MediaFile {
  id        String    @id @default(uuid())
  path      String
  type      String
  alt       String?
  size      Int?
  brands    Brand[]
  articles  Article[]
  createdAt DateTime  @default(now())
}

model SeoMeta {
  id              String  @id @default(uuid())
  entityType      String
  entityId        String
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  ogTitle         String?
  ogDescription   String?

  @@unique([entityType, entityId])
}

model CareKit {
  id               String        @id @default(uuid())
  name             String
  slug             String        @unique
  description      String?
  careTaskId       String?
  isActive         Boolean       @default(true)
  sortOrder        Int           @default(0)
  careTask         CareTask?     @relation(fields: [careTaskId], references: [id], onDelete: SetNull)
  items            CareKitItem[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model CareKitItem {
  id          String   @id @default(uuid())
  careKitId   String
  productId   String
  stepNumber  Int
  title       String?
  description String?
  careKit     CareKit  @relation(fields: [careKitId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([careKitId, stepNumber])
  @@index([productId])
}

model ProductView {
  id         String   @id @default(uuid())
  userId     String
  productId  String
  viewedAt   DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([userId, viewedAt])
  @@index([productId])
}

model ConsultationRequest {
  id             String                      @id @default(uuid())
  userId         String?
  careTaskId     String?
  assignedAdminId String?
  customerName   String
  customerEmail  String?
  customerPhone  String?
  message        String
  status         ConsultationStatus          @default(NEW)
  response       String?
  user           User?                       @relation(fields: [userId], references: [id], onDelete: SetNull)
  careTask       CareTask?                   @relation(fields: [careTaskId], references: [id], onDelete: SetNull)
  assignedAdmin  Admin?                      @relation(fields: [assignedAdminId], references: [id], onDelete: SetNull)
  products       ConsultationRequestProduct[]
  notifications  Notification[]
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt

  @@index([status, createdAt])
}

model ConsultationRequestProduct {
  consultationRequestId String
  productId             String
  consultationRequest   ConsultationRequest @relation(fields: [consultationRequestId], references: [id], onDelete: Cascade)
  product               Product             @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([consultationRequestId, productId])
}

model NotificationPreference {
  id         String              @id @default(uuid())
  userId     String
  type       NotificationType
  channel    NotificationChannel
  isEnabled  Boolean             @default(true)
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@unique([userId, type, channel])
}

model Notification {
  id                    String                 @id @default(uuid())
  userId                String
  requestOrderId        String?
  consultationRequestId String?
  type                  NotificationType
  channel               NotificationChannel
  status                NotificationStatus     @default(PENDING)
  title                 String
  message               String
  sentAt                DateTime?
  readAt                DateTime?
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  requestOrder          RequestOrder?          @relation(fields: [requestOrderId], references: [id], onDelete: SetNull)
  consultationRequest   ConsultationRequest?   @relation(fields: [consultationRequestId], references: [id], onDelete: SetNull)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  @@index([userId, status, createdAt])
}

model ProductComparison {
  id         String                  @id @default(uuid())
  userId     String
  title      String?
  user       User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  items      ProductComparisonItem[]
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt

  @@index([userId, updatedAt])
}

model ProductComparisonItem {
  comparisonId String
  productId    String
  addedAt      DateTime          @default(now())
  comparison   ProductComparison @relation(fields: [comparisonId], references: [id], onDelete: Cascade)
  product      Product           @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([comparisonId, productId])
}
