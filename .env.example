# ============================================
# WeilShop — Переменные окружения
# ============================================
# Скопируйте этот файл как .env и заполните значениями
# НИКОГДА не коммитьте файл .env с реальными данными!

# ============================================
# 🔐 Приложение
# ============================================
NODE_ENV=development
APP_PORT=3000
APP_URL=http://localhost:3000

# ============================================
# 🗄 База данных (PostgreSQL)
# ============================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/weilshop?schema=public

# Пул соединений (опционально)
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ============================================
# 💾 Кэш и сессии (Redis)
# ============================================
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=weilshop:

# ============================================
# 🔑 Аутентификация (JWT)
# ============================================
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Сложность пароля
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=false

# ============================================
# 📧 SMTP / Уведомления по email
# ============================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@weilshop.ru
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_NAME="WeilShop"
SMTP_FROM_EMAIL=noreply@weilshop.ru

# ============================================
# 📦 Хранилище файлов (S3-compatible)
# ============================================
S3_ENDPOINT=https://storage.yandexcloud.net
S3_REGION=ru-central1
S3_BUCKET=weilshop-media
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key
S3_PUBLIC_URL=https://weilshop-media.storage.yandexcloud.net

# Максимальный размер файла (в байтах)
S3_MAX_FILE_SIZE=5242880

# Разрешённые типы файлов
S3_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
S3_ALLOWED_VIDEO_TYPES=video/mp4

# ============================================
# 🌐 CORS
# ============================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_CREDENTIALS=true

# ============================================
# 🛡 Rate Limiting
# ============================================
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX_REQUESTS=100

# Строгий лимит для авторизации
RATE_LIMIT_AUTH_TTL=60
RATE_LIMIT_AUTH_MAX_REQUESTS=10

# ============================================
# 📊 Логирование
# ============================================
LOG_LEVEL=debug
LOG_FORMAT=dev

# ============================================
# 🔍 Поиск (опционально, для Meilisearch)
# ============================================
# MEILISEARCH_HOST=http://localhost:7700
# MEILISEARCH_API_KEY=your-meilisearch-key

# ============================================
# 📱 SMS-провайдер (опционально, для будущего)
# ============================================
# SMS_PROVIDER=smsc
# SMS_API_URL=https://smsc.ru/sys/send.php
# SMS_LOGIN=your-login
# SMS_PASSWORD=your-password

# ============================================
# 🔔 Telegram Bot (опционально, для уведомлений)
# ============================================
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_ADMIN_CHAT_ID=chat-id

# ============================================
# 🧪 Тестирование
# ============================================
TEST_DATABASE_URL=postgresql://postgres:password@localhost:5432/weilshop_test?schema=public
