logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Кэш
.cache/
.eslintcache
.stylelintcache

# Тесты
coverage/
.nyc_output/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Prisma
prisma/*.db
prisma/*.db-journal

# Тестовые базы данных
*.db

# Временные файлы
tmp/
temp/

# PM2
.pm2/

# Тесты e2e
playwright-report/
test-results/

# Lock files (опционально, можно коммитить)
# package-lock.json
# yarn.lock

# TypeScript build info
*.tsbuildinfo
