# ============================================
# WeilShop Backend — Переменные окружения
# ============================================

# Приложение
NODE_ENV=development
APP_PORT=3001
APP_URL=http://localhost:3001

# База данных (PostgreSQL)
DATABASE_URL=postgresql://weilshop_dev:weilshop_dev@localhost:5432/weilshop_dev

# Кэш и сессии (Redis)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PREFIX=weilshop:

# Аутентификация (JWT)
JWT_ACCESS_SECRET=dev-access-secret-key-min-32-characters
JWT_REFRESH_SECRET=dev-refresh-secret-key-min-32-characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_TTL=60
RATE_LIMIT_AUTH_MAX_REQUESTS=10

# Хранилище файлов (S3)
S3_ENDPOINT=https://storage.yandexcloud.net
S3_REGION=ru-central1
S3_BUCKET=weilshop-media
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key
S3_PUBLIC_URL=https://weilshop-media.storage.yandexcloud.net
S3_MAX_FILE_SIZE=5242880

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@weilshop.ru
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_NAME=WeilShop
SMTP_FROM_EMAIL=noreply@weilshop.ru

# Логирование
LOG_LEVEL=debug
LOG_FORMAT=dev
